---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeLogoScene from '../components/HomeLogoScene.astro';
---

<BaseLayout title="Yehia Moldan" noScroll>
  <main id="main-content" class="grid h-screen grid-rows-[1fr_auto] overflow-hidden px-6 pb-8 pt-6 md:px-10 md:pt-8">
    <section class="flex items-center justify-center">
      <HomeLogoScene />
    </section>

    <section class="mx-auto max-w-container-sm space-y-3 text-center">
      <p class="fade-in-up text-xs uppercase tracking-[0.1em] text-muted" style="animation-delay: 70ms;">Yehia Moldan</p>
      <h1 class="fade-in-up font-display text-3xl leading-tight md:text-5xl" style="animation-delay: 140ms;">Mashallah AVAV</h1>
      <p class="fade-in-up font-body text-sm text-muted md:text-base" style="animation-delay: 220ms;">
        Rotating signature mark for the monochrome portfolio storefront.
      </p>
    </section>
  </main>
</BaseLayout>
