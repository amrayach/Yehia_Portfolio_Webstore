---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getWorkItemsByCategory } from '../../lib/work';

const items = await getWorkItemsByCategory('tattoos');
---

<BaseLayout title="Tattoos | Work">
  <main class="min-h-screen px-4 pb-10 pt-6 md:px-8 md:pb-12 md:pt-8">
    <section class="mx-auto w-full max-w-container-lg space-y-6">
      <header class="space-y-3 border-b border-hairline pb-4">
        <p class="text-xs uppercase tracking-[0.1em] text-muted">Work / Tattoos</p>
        <h1 class="font-display text-3xl leading-tight md:text-5xl">Tattoo Gallery</h1>
        <a
          class="inline-flex items-center gap-2 border border-hairline px-3 py-2 text-xs uppercase tracking-[0.08em] transition-colors duration-fast ease-standard hover:border-fg"
          href="/work"
        >
          Back to Work
        </a>
      </header>

      {
        items.length === 0 ? (
          <article class="border border-hairline bg-bg p-6 text-sm text-muted md:text-base">No tattoo items published.</article>
        ) : (
          <div class="grid gap-6 md:grid-cols-2">
            {items.map((item) => (
              <article class="space-y-3 border border-hairline bg-bg p-4 md:p-5">
                {item.entry.data.image && (
                  <img
                    src={item.entry.data.image}
                    alt={item.entry.data.title}
                    loading="lazy"
                    class="aspect-[4/3] w-full border border-hairline object-cover"
                  />
                )}
                <h2 class="font-display text-2xl leading-tight">{item.entry.data.title}</h2>
                {item.entry.data.summary && <p class="font-body text-sm leading-relaxed text-muted md:text-base">{item.entry.data.summary}</p>}
              </article>
            ))}
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
