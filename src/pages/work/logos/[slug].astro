---
import Breadcrumb from '../../../components/Breadcrumb.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLogoItems, type WorkItem } from '../../../lib/work';

export const prerender = true;

export async function getStaticPaths() {
  const logos = await getLogoItems();

  return logos.map((logo) => ({
    params: {
      slug: logo.slug,
    },
    props: {
      logo,
    },
  }));
}

interface Props {
  logo: WorkItem;
}

const { logo } = Astro.props as Props;
const pdfUrl = logo.entry.data.pdfUrl;

if (!pdfUrl) {
  throw new Error(`Logo entry "${logo.slug}" is missing a pdfUrl.`);
}
---

<BaseLayout title={`${logo.entry.data.title} | Logos`}>
  <main id="main-content" class="min-h-screen px-4 pb-10 pt-6 md:px-8 md:pb-12 md:pt-8">
    <article class="mx-auto w-full max-w-container-lg space-y-6">
      <header class="space-y-3 border-b border-hairline pb-4">
        <Breadcrumb items={[{ label: 'Work', href: '/work' }, { label: 'Logos', href: '/work/logos' }, { label: logo.entry.data.title }]} />
        <h1 class="font-display text-3xl leading-tight md:text-5xl">{logo.entry.data.title}</h1>
        {logo.entry.data.summary && <p class="font-body text-sm leading-relaxed text-muted md:text-base">{logo.entry.data.summary}</p>}

        <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.08em]">
          <a
            class="inline-flex items-center gap-2 border border-fg px-3 py-2 transition-colors duration-fast ease-standard hover:bg-fg hover:text-bg"
            href={pdfUrl}
            download
            aria-label={`Download PDF for ${logo.entry.data.title}`}
          >
            Download PDF
          </a>
        </div>
      </header>

      <div class="relative border border-hairline bg-soft p-2 md:p-3" data-pdf-preview>
        <div
          data-pdf-loading
          class="absolute inset-2 grid place-items-center border border-hairline bg-bg text-xs uppercase tracking-[0.08em] text-muted md:inset-3"
        >
          Loading PDF...
        </div>
        <iframe
          data-pdf-frame
          title={`${logo.entry.data.title} PDF preview`}
          src={`${pdfUrl}#toolbar=0`}
          class="min-h-[50vh] w-full border-0 bg-bg md:min-h-[72vh]"
        ></iframe>
        <p data-pdf-error class="hidden p-3 text-xs uppercase tracking-[0.08em] text-muted">
          PDF could not be loaded.
          <a href={pdfUrl} download class="ml-2 underline underline-offset-4">
            Download directly
          </a>
        </p>
      </div>
    </article>
  </main>

  <script is:inline data-astro-rerun>
    (() => {
      const root = document.querySelector('[data-pdf-preview]');
      if (!(root instanceof HTMLElement)) {
        return;
      }

      const frame = root.querySelector('[data-pdf-frame]');
      const loading = root.querySelector('[data-pdf-loading]');
      const error = root.querySelector('[data-pdf-error]');

      if (!(frame instanceof HTMLIFrameElement) || !(loading instanceof HTMLElement) || !(error instanceof HTMLElement)) {
        return;
      }

      let settled = false;
      const hideLoading = () => {
        loading.classList.add('hidden');
      };

      const showError = () => {
        if (settled) {
          return;
        }
        settled = true;
        hideLoading();
        error.classList.remove('hidden');
      };

      const handleLoad = () => {
        if (settled) {
          return;
        }
        settled = true;
        hideLoading();
      };

      const timeoutId = window.setTimeout(showError, 12000);
      frame.addEventListener('load', handleLoad);
      frame.addEventListener('error', showError);

      const cleanup = () => {
        window.clearTimeout(timeoutId);
        frame.removeEventListener('load', handleLoad);
        frame.removeEventListener('error', showError);
        document.removeEventListener('astro:before-swap', cleanup);
      };

      document.addEventListener('astro:before-swap', cleanup);
    })();
  </script>
</BaseLayout>
