---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTextArticles } from '../lib/text';

const articles = await getTextArticles();
---

<BaseLayout title="Text | Yehia Moldan">
  <main id="main-content" class="min-h-screen px-4 pb-10 pt-6 md:px-8 md:pt-8">
    <section class="mx-auto w-full max-w-container-md space-y-6">
      <header class="space-y-2 border-b border-hairline pb-4">
        <p class="text-xs uppercase tracking-[0.1em] text-muted">Text</p>
        <h1 class="font-display text-3xl leading-tight md:text-5xl">Articles and Notes</h1>
      </header>

      {
        articles.length === 0 ? (
          <article class="border border-hairline bg-bg p-6 text-sm text-muted md:text-base">
            No published text entries found.
          </article>
        ) : (
          <div class="grid gap-px border border-hairline bg-hairline md:grid-cols-2">
            {articles.map((article) => {
              const publishDate = article.entry.data.publishDate?.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              });
              const hasPdf = Boolean(article.entry.data.pdfUrl);

              return (
                <article class="card-hover flex h-full flex-col justify-between border border-transparent bg-bg p-5 md:p-6">
                  <div class="space-y-3">
                    <p class="text-xs uppercase tracking-[0.08em] text-muted">Article</p>
                    <h2 class="font-display text-2xl leading-tight md:text-3xl">{article.entry.data.title}</h2>
                    <p class="font-body text-sm leading-relaxed text-muted md:text-base">{article.entry.data.excerpt}</p>
                  </div>

                  <div class="mt-8 space-y-4 border-t border-hairline pt-4">
                    <div class="flex flex-wrap gap-3 text-xs uppercase tracking-[0.08em] text-muted">
                      <span>~{article.readingMinutes} min read</span>
                      {publishDate && <span>{publishDate}</span>}
                      {hasPdf && <span>PDF</span>}
                    </div>

                    <a
                      class="inline-flex items-center gap-2 border border-fg px-3 py-2 text-xs uppercase tracking-[0.08em] transition-colors duration-fast ease-standard hover:bg-fg hover:text-bg"
                      href={article.url}
                      aria-label={`Read ${article.entry.data.title}`}
                    >
                      Read
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
