---
interface Props {
  targetSelector?: string;
  offsetTopPx?: number;
}

const { targetSelector = 'main', offsetTopPx = 0 } = Astro.props as Props;
---

<div class="reading-progress" data-reading-progress aria-hidden="true">
  <span class="reading-progress-bar" data-reading-progress-bar></span>
</div>

<style>
  .reading-progress {
    position: fixed;
    left: 0;
    top: 0;
    z-index: 40;
    width: 100%;
    height: 2px;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress-bar {
    display: block;
    width: 100%;
    height: 100%;
    transform-origin: left center;
    transform: scaleX(0);
    background: var(--color-fg);
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress {
      display: none;
    }
  }
</style>

<script is:inline data-astro-rerun define:vars={{ targetSelector, offsetTopPx }}>
  (() => {
    const root = document.querySelector('[data-reading-progress]');
    const bar = root?.querySelector('[data-reading-progress-bar]');
    if (!(root instanceof HTMLElement) || !(bar instanceof HTMLElement)) {
      return;
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      root.hidden = true;
      return;
    }

    const getDocumentScrollableHeight = () => {
      const documentHeight = Math.max(
        document.documentElement.scrollHeight,
        document.body?.scrollHeight ?? 0,
        document.documentElement.offsetHeight
      );
      return Math.max(1, documentHeight - window.innerHeight);
    };

    const getProgress = () => {
      const target = document.querySelector(targetSelector);
      if (target instanceof HTMLElement) {
        const targetTop = window.scrollY + target.getBoundingClientRect().top;
        const targetScrollable = Math.max(1, target.scrollHeight - window.innerHeight);
        return Math.min(1, Math.max(0, (window.scrollY + Number(offsetTopPx) - targetTop) / targetScrollable));
      }

      return Math.min(1, Math.max(0, (window.scrollY + Number(offsetTopPx)) / getDocumentScrollableHeight()));
    };

    let rafId = 0;

    const render = () => {
      rafId = 0;
      const progress = getProgress();
      bar.style.transform = `scaleX(${progress})`;
    };

    const scheduleRender = () => {
      if (rafId !== 0) {
        return;
      }
      rafId = window.requestAnimationFrame(render);
    };

    window.addEventListener('scroll', scheduleRender, { passive: true });
    window.addEventListener('resize', scheduleRender);

    const cleanup = () => {
      if (rafId !== 0) {
        window.cancelAnimationFrame(rafId);
        rafId = 0;
      }
      window.removeEventListener('scroll', scheduleRender);
      window.removeEventListener('resize', scheduleRender);
      document.removeEventListener('astro:before-swap', cleanup);
    };

    document.addEventListener('astro:before-swap', cleanup);
    scheduleRender();
  })();
</script>
